# Auth
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:9002

# Database
# These are used by docker-compose.yml for the PostgreSQL container.
# POSTGRES_PASSWORD is REQUIRED — docker-compose will fail without it.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=rulesagedb
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@localhost:5432/rulesagedb

# OpenRouter (replaces Genkit/Google AI)
OPENROUTER_API_KEY=                 # https://openrouter.ai/keys

# Email (optional)
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# App URL (optional, defaults to NEXTAUTH_URL)
# NEXT_PUBLIC_APP_URL=http://localhost:9002

# Flask debug mode (0=off, 1=on). Defaults to 0 in docker-compose. Never enable in production.
# FLASK_DEBUG=0

# Python backend URL (defaults to http://localhost:5005 for local dev; set to http://python-backend:5005 in Docker)
# PYTHON_BACKEND_URL=http://localhost:5005

# Python backend bind host. Defaults to 127.0.0.1 for safety (/execute = full RCE).
# Set to 0.0.0.0 ONLY inside an isolated Docker network where only the Next.js
# service can reach it.
# PYTHON_BACKEND_HOST=127.0.0.1

# Scheduler service shared secret (Next.js ↔ scheduler-service auth header).
# Required in production — service throws on startup if unset.
SCHEDULER_INTERNAL_SECRET=

# Internal query-db token (Python sandbox → Next.js bridge).
INTERNAL_QUERY_TOKEN=

# Data Lake: shared folder accessible by both Next.js and Python backend (relative to project root or absolute)
# DATA_LAKE_PATH=data_lake

# Email domain suffix appended to login if user omits the @ part (optional, defaults to @demo.com)
NEXT_PUBLIC_DEFAULT_EMAIL_DOMAIN=@demo.com

# WhatsApp / Groq (for audio transcription)
GROQ_API_KEY=                         # https://console.groq.com (gratuito)

# === Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# === WireGuard VPN ===
WG_SERVER_ENDPOINT=vpn.example.com
WG_SERVER_PORT=51820

# === Memory budgets (MB) — moved to UI ===
# Configure via Settings → Risorse Sistema (writes to config/system-budget.json).
# Restart dev/scheduler after change.

# === Encryption / PII ===
# 32-byte base64 key for encryption.ts.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=
# Opt-in gate for transparent PII encryption on Lead/Connector/WhatsAppContact.
# Flip to "true" ONLY after running `scripts/backfill-pii-encryption.ts`.
PII_ENCRYPTION_ENABLED=false

# === GDPR / retention cron ===
# Secret used by /api/cron/retention-cleanup and the scheduler-service
# daily 03:30 Europe/Rome job. Any random string.
CRON_SECRET=
# Upstream URL the scheduler-service posts to (inside Docker use http://app:9002).
NEXT_INTERNAL_URL=http://localhost:9002

# === Rate limit (optional distributed backend) ===
# Leave empty → in-memory (single-instance dev). Set both for Upstash Redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# LLM PII redaction is now always enabled (mandatory for GDPR compliance).
# The LLM_PII_REDACT env var is no longer used.

# === Sentry ===
# Error tracking DSN (get from https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads (optional, for CI/CD)
SENTRY_AUTH_TOKEN=
