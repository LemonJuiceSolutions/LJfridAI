{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "nextjs-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev", "--turbopack", "-p", "9002"],
      "env": { "NODE_OPTIONS": "--max-old-space-size=6144", "FORCE_COLOR": "0" },
      "port": 9002,
      "autoPort": false
    },
    {
      "name": "python-backend",
      "runtimeExecutable": "python-backend/.venv/bin/python3",
      "runtimeArgs": ["python-backend/app.py"],
      "port": 5005
    }
  ]
}
