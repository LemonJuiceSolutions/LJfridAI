{
  "name": "fridai-scheduler-service",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone scheduler microservice for FridAI — runs cron/interval tasks isolated from the Next.js process",
  "scripts": {
    "start": "NODE_OPTIONS=\"--max-old-space-size=$(node -e \"try{console.log(require('../config/system-budget.json').schedulerHeapMb||4096)}catch{console.log(4096)}\")\" tsx index.ts",
    "dev": "NODE_OPTIONS=\"--max-old-space-size=$(node -e \"try{console.log(require('../config/system-budget.json').schedulerHeapMb||4096)}catch{console.log(4096)}\")\" tsx watch index.ts",
    "typecheck": "tsc --noEmit --target ES2022 --module commonjs --moduleResolution node --esModuleInterop --allowSyntheticDefaultImports --skipLibCheck --types node server.ts shims/*.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cron-parser": "^5.5.0",
    "express": "^4.21.0",
    "lodash": "^4.17.21",
    "luxon": "^3.7.2",
    "mssql": "^12.2.0",
    "nanoid": "^5.0.7",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.5",
    "@types/luxon": "^3.7.1",
    "@types/mssql": "^9.1.8",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.4",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
