{
  "name": "fridai-scheduler-service",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone scheduler microservice for FridAI — runs cron/interval tasks isolated from the Next.js process",
  "scripts": {
    "start": "NODE_OPTIONS=\"--max-old-space-size=$(node -e \"try{console.log(require('../config/system-budget.json').schedulerHeapMb||4096)}catch{console.log(4096)}\")\" tsx index.ts",
    "dev": "NODE_OPTIONS=\"--max-old-space-size=$(node -e \"try{console.log(require('../config/system-budget.json').schedulerHeapMb||4096)}catch{console.log(4096)}\")\" tsx watch index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cron-parser": "^5.0.0",
    "express": "^4.21.0",
    "lodash": "^4.17.21",
    "luxon": "^3.5.0",
    "mssql": "^10.0.0",
    "nodemailer": "^6.9.0",
    "node-cron": "^3.0.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/lodash": "^4.17.0",
    "@types/luxon": "^3.4.0",
    "@types/mssql": "^9.1.0",
    "@types/nodemailer": "^6.4.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.7.0"
  }
}
