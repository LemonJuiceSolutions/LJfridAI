    &lt;td&gt;Nozionale al 31/12/2022&lt;/td&gt;
    &lt;td align="right"&gt;&lt;/td&gt;
    &lt;td align="right"&gt;2.193.413,54&lt;/td&gt;
   &lt;/tr&gt;
   &lt;tr&gt;
    &lt;td&gt;Fair value al 31/12/2022&lt;/td&gt;
    &lt;td align="right"&gt;&lt;/td&gt;
    &lt;td align="right"&gt;+ 214.264,58&lt;/td&gt;
   &lt;/tr&gt;
   &lt;tr&gt;
