    &lt;td width="79%"&gt;&lt;/td&gt;
    &lt;td width="1%"&gt;&lt;/td&gt;
    &lt;td&gt;&lt;/td&gt;
   &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
