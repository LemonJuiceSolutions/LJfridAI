    &lt;td align="right"&gt;&lt;/td&gt;
    &lt;td align="right"&gt;135.322,94&lt;/td&gt;
   &lt;/tr&gt;
   &lt;tr&gt;
    &lt;td&gt;Variazione riserva copertura flussi finanziari attesi&lt;/td&gt;
