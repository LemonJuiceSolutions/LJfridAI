generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT MODELS
// ============================================

model Company {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  users       User[]
  departments Department[]
  trees       Tree[]
  variables   Variable[]
  invitations Invitation[]
  connectors  Connector[]
  tokenCaches TokenCache[]
  
  // Navigation & Permissions
  navigationItems NavigationItem[]
  roles           Role[]

  // AIDRAFB Data
  products        Product[]
  materials       Material[]
  suppliers       Supplier[]
  boms            BOM[]
  inventoryItems  InventoryItem[]
  orders          Order[]
  pageLayouts     PageLayout[]
  pipelines       Pipeline[]
  connections     Connection[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  users     User[]
  
  @@index([companyId])
}

// ============================================
// NEXTAUTH.JS MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // Hashed password for credentials login
  image         String?
  role          String    @default("user") // user, admin, superadmin
  
  // OpenRouter AI Settings (per-user preferences)
  openRouterApiKey      String?
  openRouterModel       String?    @default("google/gemini-2.0-flash-001")
  openRouterAgentModel  String?    @default("google/gemini-2.0-flash-001")  // For FridAI Agent chatbot
  
  companyId     String?
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  roleId        String?
  userRole      Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  
  accounts      Account[]
  sessions      Session[]
  pageLayouts   PageLayout[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([companyId])
  @@index([departmentId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// APPLICATION MODELS (with multi-tenant support)
// ============================================

model Tree {
  id                          String   @id @default(cuid())
  name                        String
  description                 String
  naturalLanguageDecisionTree String   @db.Text
  jsonDecisionTree            String   @db.Text
  questionsScript             String   @db.Text
  createdAt                   DateTime @default(now())
  
  type                        String   @default("RULE") // RULE, PIPELINE

  companyId                   String?
  company                     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
}

model Variable {
  id             String   @id @default(cuid())
  name           String
  type           String
  possibleValues Json     @default("[]") // VariableOption[]
  createdAt      DateTime @default(now())
  
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@index([companyId])
}

model TriggerLog {
  id          String   @id @default(cuid())
  collection  String
  data        Json
  createdAt   DateTime @default(now())
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  role      String   @default("user")
  status    String   @default("PENDING") // PENDING, ACCEPTED
  expires   DateTime
  createdAt DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@unique([email, companyId])
}

model Connector {
  id        String   @id @default(cuid())
  name      String
  type      String   // SQL, HUBSPOT, SHAREPOINT, SMTP
  config    String   // JSON config
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([companyId])
}

model TokenCache {
  id        String   @id @default(cuid())
  companyId String
  provider  String   // "sharepoint", "microsoft"
  cacheData String   @db.Text // Serialized MSAL token cache
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, provider])
  @@index([companyId])
}
// ============================================
// NAVIGATION & PERMISSIONS
// ============================================

model NavigationItem {
  id          String   @id @default(cuid())
  label       String
  href        String
  icon        String
  group       String   // 'main' or 'settings'
  order       Int      @default(0)
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  requiredPermission String? // e.g., "view:dashboard"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

model Role {
  id          String       @id @default(cuid())
  name        String
  companyId   String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  permissions Permission[]
  users       User[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([companyId, name])
}

model Permission {
  id          String   @id @default(cuid())
  action      String   // e.g., "view", "create", "edit", "delete"
  resource    String   // e.g., "dashboard", "orders", "users"
  
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, action, resource])
}

// ============================================
// AIDRAFB MANUFACTURING MODELS
// ============================================

model Product {
  id          String   @id @default(cuid())
  sku         String   
  name        String
  category    String?
  price       Float
  imageUrl    String?
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  inventory   InventoryItem[]
  orderLines  OrderItem[]
  boms        BOM[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, sku])
}

model Material {
  id          String   @id @default(cuid())
  code        String
  name        String
  unit        String
  costPerUnit Float?
  
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  bomComponents BOMComponent[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, code])
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  rating      Float?
  leadTime    String?
  minOrder    Int?
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  materials   Material[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BOM {
  id          String   @id @default(cuid())
  name        String
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  components  BOMComponent[]
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BOMComponent {
  id          String   @id @default(cuid())
  bomId       String
  bom         BOM      @relation(fields: [bomId], references: [id], onDelete: Cascade)
  
  materialId  String
  material    Material @relation(fields: [materialId], references: [id])
  
  quantity    Float
}

model InventoryItem {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  quantity    Int
  location    String?
  size        String?
  color       String?

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  updatedAt   DateTime @updatedAt
}

model Order {
  id          String   @id @default(cuid())
  externalId  String?  // e.g. ORD5001
  customerName String
  date        DateTime
  status      String   @default("Pending")
  total       Float
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  items       OrderItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  quantity    Int
  price       Float
  status      String? // For production tracking per item (e.g. Cutting, Sewing)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageLayout {
  id          String   @id @default(cuid())
  pageId      String   // e.g. "dashboard", "/001"
  
  layouts     Json
  items       Json

  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  userId      String?  // Optional: if specific to a user
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, pageId, userId]) // Unique layout per page per user (or company if user null)
}

model Pipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  nodes       Json
  edges       Json
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Connection {
  id          String   @id @default(cuid())
  name        String   // e.g. "Production DB"
  type        String   // e.g. "postgres", "mysql", "api"
  config      Json     // Encrypted connection details? For now plain text or handled by env.
  
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
